# Copy this file to .env and fill in real values.
# Docker Compose reads .env automatically; for local dev without Docker,
# export these variables in your shell or use a tool like direnv.

# ─── Shared secret (must be the same value everywhere) ───────────────────────
INTERNAL_SECRET=change-me-internal-secret

# ─── auth-api ────────────────────────────────────────────────────────────────
AUTH_PORT=8081
AUTH_DATABASE_URL=postgres://trippier:trippier@localhost:5432/trippier?sslmode=disable
AUTH_REDIS_URL=redis://localhost:6379
AUTH_JWT_SECRET=change-me-in-production-32-chars!!
AUTH_INTERNAL_SECRET=change-me-internal-secret
AUTH_SMTP_HOST=localhost
AUTH_SMTP_PORT=1025
AUTH_SMTP_FROM=noreply@trippier.dev
AUTH_APP_URL=http://localhost:3000
AUTH_DEFAULT_TOKENS_LIMIT=1000
AUTH_DEFAULT_RESET_INTERVAL_S=3600

# ─── poi-api ─────────────────────────────────────────────────────────────────
POI_PORT=8080
POI_REDIS_URL=redis://localhost:6379
POI_CACHE_TTL_SECONDS=3600
POI_PROVIDER_TIMEOUT=8
POI_LANG=en
POI_LOG_LEVEL=info
POI_AUTH_API_URL=http://localhost:8081
POI_INTERNAL_SECRET=change-me-internal-secret
# Optional — free account at https://www.geonames.org/login
POI_GEONAMES_USERNAME=

# ─── itinerary-api ───────────────────────────────────────────────────────────
POI_API_URL=http://localhost:8080
POI_CLIENT_TIMEOUT=10.0
LOG_LEVEL=info
AUTH_API_URL=http://localhost:8081

# ─── frontend ────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── Ports (override for docker-compose.full.yml) ────────────────────────────
AUTH_API_PORT=8081
POI_API_PORT=8080
ITINERARY_API_PORT=8000
FRONTEND_PORT=3000
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
